                { name: "%$ADMINTOOLS%", desc: "관리 도구", cat: "가상 경로", tip: "윈도우 관리 도구." },
                
                // OS 환경 (%)
                { name: "%windir%", desc: "Windows 폴더", cat: "OS 환경", tip: "C:\\Windows 경로." },
                { name: "%SystemRoot%", desc: "시스템 루트", cat: "OS 환경", tip: "OS 설치 경로." },
                { name: "%SystemDrive%", desc: "시스템 드라이브", cat: "OS 환경", tip: "OS 설치 드라이브(C:)." },
