<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>토탈 커맨더 인터랙티브 마스터 가이드 - 전수 수록 통합본</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;600;700&display=swap');
        body { font-family: 'Pretendard', sans-serif; }
        .tab-active { border-bottom: 4px solid #2563eb; color: #1e40af; font-weight: 700; }
        .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #f8fafc; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); border: 1px solid rgba(226, 232, 240, 0.8); }
        .param-chip { @apply px-3 py-1 rounded-full text-[11px] font-bold border transition-all cursor-pointer shadow-sm; }
        .command-row:hover { background-color: rgba(37, 99, 235, 0.03); }
        .copyable-cmd { cursor: pointer; transition: all 0.2s; position: relative; }
        .copyable-cmd:hover { color: #2563eb; text-decoration: underline; }
        .sticky-header { position: sticky; top: 0; z-index: 50; background: #f1f5f9; }
        .recipe-card { min-height: 250px; }
    </style>
</head>
<body class="bg-stone-50 text-slate-800 min-h-screen flex flex-col text-sm">

    <!-- Header Section -->
    <header class="bg-white/90 sticky top-0 z-50 border-b border-stone-200 backdrop-blur-md border-t-4 border-t-blue-600 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3 group cursor-pointer" onclick="app.switchTab(0)">
                <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center text-white text-2xl shadow-lg group-hover:scale-110 transition-transform">📂</div>
                <div>
                    <h1 class="text-xl font-black text-slate-900 tracking-tight uppercase leading-none">TC Master Ultimate</h1>
                    <p class="text-[10px] text-blue-600 font-bold uppercase tracking-widest mt-1">Full Data & 40 Recipes Integrated</p>
                </div>
            </div>
            
            <div class="relative w-full md:w-1/3">
                <input type="text" id="globalSearch" placeholder="ID, 명령어, 레시피, 변수 등 통합 검색..." 
                    class="w-full bg-stone-100 border-none rounded-full py-2.5 pl-10 pr-4 focus:ring-2 focus:ring-blue-500 transition-all outline-none text-sm shadow-inner">
                <span class="absolute left-3 top-2.5 text-stone-400">🔍</span>
            </div>
        </div>

        <nav class="max-w-7xl mx-auto px-4 overflow-x-auto custom-scrollbar">
            <div class="flex space-x-8 border-b border-stone-200 whitespace-nowrap" id="navContainer">
            </div>
        </nav>
    </header>

    <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8" id="viewContainer">
    </main>

    <footer class="bg-white border-t border-stone-200 py-8 mt-10">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-stone-400 text-[10px] font-medium uppercase tracking-widest mb-1">Total Commander Ultimate Master Guide</p>
            <p class="text-stone-300 text-[9px] font-light italic">모든 데이터가 주신 원본 텍스트에 기반하여 전수 수록되었습니다.</p>
        </div>
    </footer>

    <script>
        const db = {
            categories: [
                { id: 0, title: "단축키 사전", icon: "⌨️" },
                { id: 1, title: "매개변수 & 옵션", icon: "🚀" },
                { id: 2, title: "시스템 변수 전체", icon: "🧩" },
                { id: 3, title: "버튼바 레시피 (40선)", icon: "🔘" },
                { id: 4, title: "내부 명령", icon: "📜" }
            ],
            shortcuts: [
                { key: "F1", desc: "도움말 호출", cat: "기능키", tip: "상황에 맞는 도움말 표시" },
                { key: "F2", desc: "새로고침", cat: "기능키", tip: "소스 윈도우 목록 업데이트" },
                { key: "F3", desc: "파일 보기", cat: "기능키", tip: "Lister 실행 (내용 보기)" },
                { key: "F4", desc: "파일 편집", cat: "기능키", tip: "에디터 실행" },
                { key: "F5", desc: "복사", cat: "기능키", tip: "반대편 창으로 복사" },
                { key: "F6", desc: "이동/이름변경", cat: "기능키", tip: "파일 이동/변경" },
                { key: "F7", desc: "새 폴더", cat: "기능키", tip: "디렉토리 생성" },
                { key: "F8 / Del", desc: "삭제", cat: "기능키", tip: "휴지통으로" },
                { key: "F9", desc: "메뉴 활성화", cat: "기능키", tip: "상단 메뉴 포커스" },
                { key: "F10", desc: "왼쪽 메뉴 / 종료", cat: "기능키", tip: "메뉴 활성화 또는 종료" },
                { key: "F11", desc: "왼쪽 드라이브바 포커스", cat: "기능키", tip: "왼쪽 드라이브 영역 이동" },
                { key: "F12", desc: "오른쪽 드라이브바 포커스", cat: "기능키", tip: "오른쪽 드라이브 영역 이동" },
                { key: "Alt + F1", desc: "왼쪽 드라이브 목록", cat: "Alt", tip: "왼쪽 드라이브 선택창" },
                { key: "Alt + F2", desc: "오른쪽 드라이브 목록", cat: "Alt", tip: "오른쪽 드라이브 선택창" },
                { key: "Alt + F5", desc: "파일 압축", cat: "Alt", tip: "선택 파일 압축" },
                { key: "Alt + F7", desc: "찾기", cat: "Alt", tip: "상세 검색 창" },
                { key: "Alt + Enter", desc: "속성", cat: "Alt", tip: "윈도우 속성창" },
                { key: "Ctrl + A", desc: "전체 선택", cat: "Ctrl", tip: "모두 선택" },
                { key: "Ctrl + B", desc: "분기 보기", cat: "Ctrl", tip: "하위 파일 평면화" },
                { key: "Ctrl + D", desc: "즐겨찾기", cat: "Ctrl", tip: "핫리스트" },
                { key: "Ctrl + M", desc: "일괄 이름 변경", cat: "Ctrl", tip: "Multi-Rename Tool" },
                { key: "Ctrl + Q", desc: "퀵 뷰", cat: "Ctrl", tip: "미리보기" },
                { key: "Ctrl + T", desc: "새 탭", cat: "Ctrl", tip: "현재 창 복제" },
                { key: "Ctrl + U", desc: "스왑", cat: "Ctrl", tip: "경로 교체" },
                { key: "Ctrl + \\", desc: "루트 이동", cat: "Ctrl", tip: "최상위 폴더" },
                { key: "Backspace", desc: "상위 폴더", cat: "기타", tip: "부모 디렉토리" },
                { key: "Insert", desc: "선택", cat: "기타", tip: "선택 후 아래로" },
                { key: "Space", desc: "선택 및 용량", cat: "기타", tip: "폴더 용량 계산" },
                { key: "Num +", desc: "일괄 선택", cat: "기타", tip: "확장자 패턴 선택" },
                { key: "Num -", desc: "일괄 해제", cat: "기타", tip: "확장자 패턴 해제" },
                { key: "Num *", desc: "선택 반전", cat: "기타", tip: "선택 항목 뒤집기" }
            ],
            params: [
                { code: "%P", desc: "소스 경로 (\\ 포함)", cat: "경로", tip: "현재 활성 창의 전체 경로." },
                { code: "%p", desc: "소스 경로 (\\ 제외)", cat: "경로", tip: "역슬래시 제외 소스 경로." },
                { code: "%N", desc: "선택된 파일명", cat: "이름", tip: "커서 위치 파일명(확장자 포함)." },
                { code: "%n", desc: "파일명 (확장자 제외)", cat: "이름", tip: "이름 본문만 추출." },
                { code: "%O", desc: "파일명 본문 (Name)", cat: "이름", tip: "확장자 제외 순수 이름." },
                { code: "%E", desc: "확장자 (Ext)", cat: "이름", tip: "순수 확장자(점 미포함)." },
                { code: "%T", desc: "타겟 경로 (\\ 포함)", cat: "경로", tip: "반대편 창의 전체 경로." },
                { code: "%t", desc: "타겟 경로 (\\ 제외)", cat: "경로", tip: "반대편 창 역슬래시 제외." },
                { code: "%M", desc: "타겟 창 선택 파일명", cat: "이름", tip: "반대편 창 커서 위치 파일명." },
                { code: "%S", desc: "선택된 모든 파일명", cat: "목록", tip: "선택 파일 목록 공백 구분." },
                { code: "%D", desc: "선택된 모든 파일 경로", cat: "목록", tip: "전체 경로 목록 공백 구분." },
                { code: "%V", desc: "현재 폴더명", cat: "이름", tip: "마지막 폴더 이름만 추출." },
                { code: "%L", desc: "ANSI 리스트 생성", cat: "리스트", tip: "임시 .txt 리스트 파일 생성." },
                { code: "%WL", desc: "UTF-16 리스트 생성", cat: "리스트", tip: "유니코드 방식 리스트." },
                { code: "%UL", desc: "UTF-8 리스트 생성", cat: "리스트", tip: "UTF-8 인코딩 리스트 생성." },
                { code: "%X", desc: "매개변수 숨김 시작", cat: "특수", tip: "명령줄에 표시 안 됨." },
                { code: "%Y", desc: "따옴표 자동 추가 안함", cat: "특수", tip: "긴 경로 따옴표 무시." },
                { code: "%K", desc: "실행 후 창 유지", cat: "특수", tip: "콘솔 종료 후 대기." },
                { code: "%A", desc: "압축 내 파일 지원", cat: "특수", tip: "압축 내부 파일 파라미터 가능." },
                { code: "/O", desc: "기존 창 활성화", cat: "실행", tip: "이미 실행된 TC에 전달." },
                { code: "/N", desc: "무조건 새 창 실행", cat: "실행", tip: "항상 새로운 인스턴스." },
                { code: "/T", desc: "새 탭으로 열기", cat: "실행", tip: "현재 탭 옆에 새 탭 생성." },
                { code: "/L=", desc: "왼쪽 경로 지정", cat: "실행", tip: "왼쪽 패널 초기 경로 설정." },
                { code: "/R=", desc: "오른쪽 경로 지정", cat: "실행", tip: "오른쪽 패널 초기 경로 설정." },
                { code: "/S=C", desc: "파일 비교 도구", cat: "실행", tip: "내용 비교 창 즉시 실행." },
                { code: "/S=S", desc: "동기화 도구", cat: "실행", tip: "디렉토리 동기화 즉시 실행." }
            ],
            vars: [
                // TC 전용
                { name: "%COMMANDER_PATH%", desc: "TC 설치 폴더", cat: "TC 전용", tip: "설치된 루트 디렉토리." },
                { name: "%COMMANDER_EXE%", desc: "TC 실행 파일 경로", cat: "TC 전용", tip: "totalcmd.exe 전체 경로." },
                { name: "%COMMANDER_INI%", desc: "로드된 설정 파일", cat: "TC 전용", tip: "wincmd.ini 절대 경로." },
                { name: "%COMMANDER_DRIVE%", desc: "TC 설치 드라이브", cat: "TC 전용", tip: "드라이브 문자(예: C:)." },
                { name: "%COMMANDER_CLP%", desc: "내부 클립보드 데이터", cat: "TC 전용", tip: "클립보드 내용 참조용." },
                { name: "%COMMANDER_LANGUAGE%", desc: "현재 설정 언어", cat: "TC 전용", tip: "사용 중인 언어 정보." },
                { name: "%COMMANDER_EXE_X64%", desc: "64비트 실행 파일", cat: "TC 전용", tip: "64비트 전용 파일 경로." },
                
                // 가상 경로 ($)
                { name: "%$DESKTOP%", desc: "바탕 화면", cat: "가상 경로", tip: "사용자 바탕 화면 가상 경로." },
                { name: "%$PERSONAL%", desc: "내 문서", cat: "가상 경로", tip: "사용자 문서(Documents) 폴더." },
                { name: "%$DOWNLOADS%", desc: "다운로드 폴더", cat: "가상 경로", tip: "시스템 기본 다운로드 위치." },
                { name: "%$PICTURES%", desc: "사진 폴더", cat: "가상 경로", tip: "라이브러리 사진 폴더." },
                { name: "%$MUSIC%", desc: "음악 폴더", cat: "가상 경로", tip: "라이브러리 음악 폴더." },
                { name: "%$VIDEOS%", desc: "동영상 폴더", cat: "가상 경로", tip: "라이브러리 비디오 폴더." },
