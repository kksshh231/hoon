                { title: "Everything 연동 검색", cat: "탐색", cmd: "Everything.exe", param: "-path \"%P\"", tip: "현재 폴더 대상 Everything 검색 시작." },
                { title: "바탕 화면 바로가기", cat: "탐색", cmd: "cd $DESKTOP", param: "", tip: "바탕 화면 폴더로 이동." },
