                { name: "%$RECYCLEBIN%", desc: "휴지통", cat: "가상 경로", tip: "휴지통 가상 폴더." },
                { name: "%$DRIVES%", desc: "내 PC / 드라이브", cat: "가상 경로", tip: "전체 드라이브 목록." },
                { name: "%$NETWORK%", desc: "네트워크 환경", cat: "가상 경로", tip: "공유 리스트." },
                { name: "%$PRINTERS%", desc: "프린터 목록", cat: "가상 경로", tip: "프린터 및 팩스." },
