                { id: 481, cmd: "cm_LogConfig", desc: "구성: 로그 파일", cat: "Config" },
                { id: 480, cmd: "cm_IgnoreConfig", desc: "구성: 무시 목록", cat: "Config" },
                { id: 475, cmd: "cm_HistoryConfig", desc: "구성: 사용 내역", cat: "Config" },
                { id: 491, cmd: "cm_PackerConfig", desc: "구성: 압축기", cat: "Config" },
                { id: 485, cmd: "cm_ZipPackerConfig", desc: "구성: ZIP 압축기", cat: "Config" },
                { id: 474, cmd: "cm_7ZipPackerConfig", desc: "구성: 7-ZIP 압축기", cat: "Config" },
                { id: 495, cmd: "cm_Confirmation", desc: "구성: 기타, 확인", cat: "Config" },
                { id: 493, cmd: "cm_ConfigSavePos", desc: "구성: 위치 저장", cat: "Config" },
                { id: 498, cmd: "cm_ButtonConfig", desc: "구성: 버튼 표시줄", cat: "Config" },
                { id: 583, cmd: "cm_ButtonConfig2", desc: "구성: 버튼 표시줄 2 (수직)", cat: "Config" },
                { id: 580, cmd: "cm_ConfigSaveSettings", desc: "현재 설정 등 저장", cat: "Config" },
                { id: 581, cmd: "cm_ConfigChangeIniFiles", desc: "메모장에서 ini 파일 열기", cat: "Config" },
                { id: 582, cmd: "cm_ConfigSaveDirHistory", desc: "디렉터리 사용 내역 저장", cat: "Config" },
                { id: 700, cmd: "cm_ChangeStartMenu", desc: "시작 메뉴 변경", cat: "Config" },

                /* NETWORK & MISC */
                { id: 512, cmd: "cm_NetConnect", desc: "네트워크 연결", cat: "Net" },
                { id: 513, cmd: "cm_NetDisconnect", desc: "네트워크 끊기", cat: "Net" },
                { id: 514, cmd: "cm_NetShareDir", desc: "디렉터리 공유", cat: "Net" },
                { id: 515, cmd: "cm_NetUnshareDir", desc: "디렉터리 공유 해제", cat: "Net" },
                { id: 503, cmd: "cm_GetFileSpace", desc: "공간 계산", cat: "Misc" },
                { id: 511, cmd: "cm_ExecuteDOS", desc: "명령 프롬프트 열기", cat: "Misc" },
                { id: 533, cmd: "cm_CompareDirs", desc: "디렉터리 비교", cat: "Misc" },
                { id: 2600, cmd: "cm_SyncChangeDir", desc: "두 창 동기화 디렉토리 변경", cat: "Misc" },
                { id: 531, cmd: "cm_Exchange", desc: "패널 교환", cat: "Misc" }
            ]
        };

        const extendData = () => {
            const sections = [
                { name: "User", start: 701, end: 710, prefix: "cm_UserMenu", desc: "사용자 메뉴 N번" },
                { name: "Tabs", start: 5001, end: 5010, prefix: "cm_SrcActivateTab", desc: "원본: N번 탭 활성화" },
                { name: "Tabs", start: 5101, end: 5110, prefix: "cm_TrgActivateTab", desc: "대상: N번 탭 활성화" },
                { name: "Tabs", start: 5201, end: 5210, prefix: "cm_LeftActivateTab", desc: "왼쪽: N번 탭 활성화" },
                { name: "Tabs", start: 5301, end: 5310, prefix: "cm_RightActivateTab", desc: "오른쪽: N번 탭 활성화" },
                { name: "Sort", start: 6001, end: 6010, prefix: "cm_SrcSortByCol", desc: "원본: N번째 열 정렬" },
                { name: "Sort", start: 6101, end: 6110, prefix: "cm_TrgSortByCol", desc: "대상: N번째 열 정렬" },
                { name: "Sort", start: 6201, end: 6210, prefix: "cm_LeftSortByCol", desc: "왼쪽: N번째 열 정렬" },
                { name: "Sort", start: 6301, end: 6310, prefix: "cm_RightSortByCol", desc: "오른쪽: N번째 열 정렬" }
            ];
            sections.forEach(sec => {
                for(let i=sec.start; i<=sec.end; i++) {
                    const idx = i - sec.start + 1;
                    db.internalCommands.push({ id: i, cmd: `${sec.prefix}${idx}`, desc: sec.desc.replace('N', idx), cat: sec.name });
                }
            });
            for(let i=1; i<=9; i++) db.internalCommands.push({ id: 270+i, cmd: `cm_SrcCustomView${i}`, desc: `원본: 사용자 열 ${i}`, cat: "CustomView" });
            for(let i=0; i<=9; i++) db.internalCommands.push({ id: 8500+i, cmd: `cm_SrcViewMode${i}`, desc: `원본: 보기 모드 ${i}`, cat: "ViewMode" });
            const paramBase = [
                { id: -2, cmd: "CD <directory>", desc: "지정된 디렉토리 전환" },
                { id: -11, cmd: "SELECTFILES <*.ext>", desc: "확장자별 선택" },
                { id: -12, cmd: "CM_WAIT <time>", desc: "밀리초 대기" }
            ];
            paramBase.forEach(p => db.internalCommands.push({ ...p, cat: "Params" }));
        };
        extendData();

        const app = {
            state: { currentTab: 0, query: "", paramFilter: "전체", varFilter: "전체", testCommand: "/N /O /L=\"%P%N\"" },

            init() {
                this.renderNav();
                this.switchTab(0);
                this.bindSearch();
            },

            bindSearch() {
                const search = document.getElementById('globalSearch');
                search.addEventListener('input', (e) => {
                    this.state.query = e.target.value.toLowerCase();
                    if (this.state.query.length > 0) this.renderSearchResults();
                    else this.switchTab(this.state.currentTab);
                });
            },

            renderNav() {
                const nav = document.getElementById('navContainer');
                nav.innerHTML = db.categories.map(c => `
                    <button onclick="app.switchTab(${c.id})" 
                        class="px-4 py-4 text-[13px] font-semibold transition-all flex items-center gap-2 
                        ${this.state.currentTab === c.id ? 'tab-active' : 'text-stone-400 hover:text-slate-600'}">
                        <span>${c.icon}</span> ${c.title}
                    </button>
                `).join('');
            },

            switchTab(id) {
                this.state.currentTab = id;
                this.renderNav();
                const container = document.getElementById('viewContainer');
                container.innerHTML = "";
                
                switch(id) {
                    case 0: this.viewShortcuts(container); break;
                    case 1: this.viewParams(container); break;
                    case 2: this.viewVars(container); break;
                    case 3: this.viewButtons(container); break;
                    case 4: this.viewInternalCommands(container); break;
                }
            },

            viewShortcuts(container) {
                container.innerHTML = `
                    <div class="space-y-6 animate-in fade-in duration-500">
                        <h2 class="text-xl font-black text-slate-800 tracking-tighter italic">⌨️ 단축키 사전</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
                            ${db.shortcuts.map(s => `
                                <div class="bg-white border border-stone-200 p-4 rounded-xl hover:border-blue-400 transition-all group shadow-sm">
                                    <div class="flex justify-between items-start mb-2">
                                        <code class="bg-blue-50 text-blue-700 font-black px-2 py-0.5 rounded text-[11px]">${s.key}</code>
                                        <span class="text-[8px] uppercase font-black text-stone-300 tracking-tighter">${s.cat}</span>
                                    </div>
                                    <h4 class="font-bold text-slate-800 text-[13px]">${s.desc}</h4>
                                    <p class="text-[10px] text-stone-400 mt-1 leading-tight">${s.tip}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            },

            viewParams(container) {
                const paramCats = ["전체", ...new Set(db.params.map(p => p.cat))];
                container.innerHTML = `
                    <div class="space-y-6 animate-in fade-in duration-500">
                        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                            <h2 class="text-xl font-black text-slate-800 tracking-tighter italic">🚀 매개변수 & 옵션</h2>
                            <div class="flex flex-wrap gap-1.5 justify-center">
                                ${paramCats.map(cat => `<button onclick="app.filterParams('${cat}')" class="param-chip ${this.state.paramFilter === cat ? 'bg-blue-600 text-white border-blue-600 shadow-md' : 'bg-white text-stone-400 border-stone-200 hover:border-blue-400'}">${cat}</button>`).join('')}
                            </div>
                        </div>
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <div class="glass-card p-4 rounded-3xl space-y-1 max-h-[550px] overflow-y-auto custom-scrollbar border shadow-inner bg-stone-100/50">
                                ${this.renderParamList()}
                            </div>
                            <div class="glass-card p-6 rounded-3xl sticky top-24 h-fit border-blue-100 bg-blue-50/20 shadow-xl">
                                <h3 class="text-[13px] font-black mb-3 uppercase tracking-widest text-blue-800 flex items-center gap-2">🛠️ 명령줄 조합기</h3>
                                <div class="p-4 bg-slate-900 text-emerald-400 font-mono rounded-xl mb-4 min-h-[70px] break-all text-xs leading-relaxed border-2 border-slate-800 shadow-2xl" id="paramResult">${this.state.testCommand}</div>
                                <button onclick="app.copyVal('paramResult')" class="w-full py-3 bg-blue-600 text-white font-bold rounded-xl shadow-lg hover:bg-blue-700 transition-colors text-xs active:scale-95">결과 복사</button>
                                <button onclick="app.clearTest()" class="w-full mt-2 py-1 text-[10px] text-stone-400 hover:text-red-500 font-bold">비우기</button>
                            </div>
                        </div>
                    </div>
                `;
            },

            renderParamList() {
                const list = this.state.paramFilter === "전체" ? db.params : db.params.filter(p => p.cat === this.state.paramFilter);
                return list.map(p => `
                    <div class="flex items-center gap-4 p-2.5 bg-white hover:bg-blue-50 rounded-xl transition-all group cursor-pointer border border-stone-100 shadow-sm" onclick="app.appendToTest('${p.code}')">
                        <code class="text-blue-600 font-black min-w-[55px] text-center text-[12px] bg-blue-50 rounded py-0.5">${p.code}</code>
                        <div class="flex-grow"><p class="text-xs font-bold text-slate-800">${p.desc}</p></div>
                    </div>
                `).join('');
            },

            viewVars(container) {
                const varCats = ["전체", "TC 전용", "가상 경로", "OS 환경"];
                container.innerHTML = `
                    <div class="space-y-6 animate-in fade-in duration-500 text-center">
                        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                            <h2 class="text-xl font-black text-slate-800 tracking-tighter italic">🧩 시스템 및 TC 내장 변수</h2>
                            <div class="flex flex-wrap gap-1.5 justify-center">
                                ${varCats.map(cat => `<button onclick="app.filterVars('${cat}')" class="param-chip ${this.state.varFilter === cat ? 'bg-blue-600 text-white border-blue-600 shadow-md scale-105' : 'bg-white text-stone-400 border-stone-200 hover:border-blue-400'}">${cat}</button>`).join('')}
                            </div>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 text-left">
                            ${this.renderVarCards()}
                        </div>
                    </div>
                `;
            },

            renderVarCards() {
                const list = this.state.varFilter === "전체" ? db.vars : db.vars.filter(v => v.cat === this.state.varFilter);
                return list.map(v => `
                    <div class="bg-white p-4 rounded-xl border border-stone-200 group hover:border-blue-500 transition-all shadow-sm flex flex-col justify-between h-full">
                        <div>
                            <code class="text-blue-700 font-black text-[11px] block mb-1">${v.name}</code>
                            <h4 class="text-slate-800 font-bold mb-1 text-[12px]">${v.desc}</h4>
                            <p class="text-[10px] text-stone-400 mb-3 leading-tight">${v.tip}</p>
                        </div>
                        <button onclick="app.copyToClipboard('${v.name}')" class="w-full py-1.5 bg-stone-50 text-stone-400 text-[9px] font-black rounded-lg group-hover:bg-blue-600 group-hover:text-white transition-all uppercase tracking-widest">Copy</button>
                    </div>
                `).join('');
            },

            viewButtons(container) {
                container.innerHTML = `
                    <div class="max-w-7xl mx-auto space-y-6 animate-in fade-in duration-500">
                        <h2 class="text-xl font-black text-slate-800 tracking-tighter italic">🔘 실전 버튼바 레시피 40선</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                            ${db.buttonPresets.map((p, idx) => `
                                <div class="glass-card p-5 rounded-2xl border border-stone-200 hover:border-blue-400 transition-all flex flex-col shadow-md recipe-card">
                                    <div class="flex justify-between items-start mb-3">
                                        <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[8px] font-black border border-blue-100 uppercase">${p.cat}</span>
                                        <span class="text-stone-200 font-black text-sm">#${(idx+1).toString().padStart(2, '0')}</span>
                                    </div>
                                    <h3 class="font-black text-slate-800 mb-1 text-sm">${p.title}</h3>
                                    <p class="text-[11px] text-stone-400 mb-4 flex-grow font-medium leading-relaxed">${p.tip}</p>
                                    <div class="space-y-2 bg-stone-100/80 p-3 rounded-xl border border-stone-200">
                                        <div class="cursor-pointer group" onclick="app.copyToClipboard('${p.cmd}')">
                                            <p class="text-[8px] font-bold text-stone-400 uppercase">명령 (Cmd)</p>
                                            <code class="text-[10px] font-bold text-blue-700 break-all bg-white px-2 py-0.5 rounded block group-hover:bg-blue-50 border border-stone-200">${p.cmd}</code>
                                        </div>
                                        ${p.param ? `<div class="cursor-pointer group" onclick="app.copyToClipboard('${p.param}')"><p class="text-[8px] font-bold text-stone-400 uppercase">매개변수 (Param)</p><code class="text-[10px] font-bold text-emerald-700 break-all bg-white px-2 py-0.5 rounded block group-hover:bg-emerald-50 border border-stone-200">${p.param}</code></div>` : '<p class="text-[8px] text-stone-300 italic uppercase">No Param</p>'}
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                `;
            },

            viewInternalCommands(container) {
                container.innerHTML = `
                    <div class="space-y-4 animate-in fade-in duration-500">
                        <h2 class="text-xl font-black text-slate-800 tracking-tighter italic">📜 내부 명령</h2>
                        <div class="glass-card rounded-2xl overflow-hidden border border-stone-200 shadow-2xl">
                            <div class="overflow-x-auto custom-scrollbar" style="max-height: 75vh;">
                                <table class="w-full text-left border-collapse table-auto">
                                    <thead class="sticky-header shadow-sm border-b border-slate-300">
                                        <tr class="text-[9px] uppercase font-black text-slate-600">
                                            <th class="px-4 py-3 w-12 text-center">ID</th>
                                            <th class="px-4 py-3 w-64">내부 명령 (클릭 시 복사)</th>
                                            <th class="px-4 py-3">설명 (Description)</th>
                                            <th class="px-4 py-3 w-24 text-center text-slate-500 uppercase tracking-tighter">카테고리</th>
                                        </tr>
                                    </thead>
                                    <tbody id="cmdTableBody" class="text-[11px]">
                                        ${this.renderCommandList(db.internalCommands)}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                `;
            },

            getInternalCatTextColor(cat) {
                const colors = {
                    "Source": "text-blue-600 font-bold",
                    "Left": "text-indigo-600 font-bold",
                    "Right": "text-purple-600 font-bold",
                    "File Ops": "text-emerald-600 font-bold",
                    "Config": "text-orange-600 font-bold",
                    "Net": "text-cyan-600 font-bold",
                    "Misc": "text-slate-600 font-bold",
                    "Mark": "text-rose-600 font-bold",
                    "Clip": "text-teal-600 font-bold",
                    "Nav": "text-lime-600 font-bold",
                    "Tabs": "text-pink-600 font-bold",
                    "Sort": "text-amber-600 font-bold",
                    "User": "text-fuchsia-600 font-bold",
                    "View": "text-sky-600 font-bold",
                    "Window": "text-gray-500 font-bold",
                    "Params": "text-red-600 font-bold",
                    "CustomView": "text-amber-600 font-bold",
                    "ViewMode": "text-neutral-600 font-bold"
                };
                return colors[cat] || "text-stone-400 font-bold";
            },

            renderCommandList(list) {
                return list.map(c => {
                    const colorClass = this.getInternalCatTextColor(c.cat);
                    return `
                    <tr class="command-row border-b border-stone-100 transition-colors">
                        <td class="px-4 py-2.5 font-mono text-stone-400 text-[10px] text-center">${c.id}</td>
                        <td class="px-4 py-2.5 font-bold ${colorClass} copyable-cmd rounded-md" onclick="app.copyToClipboard('${c.cmd}')">${c.cmd}</td>
                        <td class="px-4 py-2.5 text-stone-600 font-medium">${c.desc}</td>
                        <td class="px-4 py-2.5 text-center">
                            <span class="${colorClass} text-[9px] uppercase tracking-tighter">${c.cat}</span>
                        </td>
                    </tr>
                `}).join('');
            },

            renderSearchResults() {
                const container = document.getElementById('viewContainer');
                const query = this.state.query;
                const sRes = db.shortcuts.filter(s => s.key.toLowerCase().includes(query) || s.desc.toLowerCase().includes(query));
                const pRes = db.params.filter(p => p.code.toLowerCase().includes(query) || p.desc.toLowerCase().includes(query));
                const vRes = db.vars.filter(v => v.name.toLowerCase().includes(query) || v.desc.toLowerCase().includes(query));
                const cRes = db.internalCommands.filter(c => c.cmd.toLowerCase().includes(query) || c.desc.toLowerCase().includes(query));

                container.innerHTML = `
                    <div class="space-y-6 animate-in fade-in duration-300">
                        <h2 class="text-xl font-black text-slate-800 italic">"${query}" 통합 검색 결과 (${sRes.length + pRes.length + vRes.length + cRes.length})</h2>
                        ${cRes.length > 0 ? `<section><h3 class="font-black text-[10px] text-stone-400 mb-2 uppercase tracking-widest">내부 명령 (cm_)</h3><div class="glass-card p-3 rounded-2xl space-y-1 max-h-96 overflow-y-auto custom-scrollbar border shadow-inner bg-stone-100/50">${cRes.map(c => `<div class="flex items-center justify-between p-2 bg-white rounded-lg cursor-pointer hover:border-blue-400 border border-stone-100 transition-all shadow-sm" onclick="app.copyToClipboard('${c.cmd}')"><code class="text-blue-600 font-bold text-xs">${c.cmd}</code><span class="text-[11px] font-medium text-slate-500">${c.desc}</span></div>`).join('')}</div></section>` : ''}
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            ${sRes.length > 0 ? `<section><h3 class="font-black text-[10px] text-stone-400 mb-2 uppercase tracking-widest">단축키</h3><div class="grid grid-cols-1 gap-2">${sRes.map(s => `<div class="bg-white border p-3 rounded-xl font-bold text-xs shadow-sm flex justify-between"><span>${s.key}</span><span class="text-stone-400 text-[10px] font-normal italic">${s.desc}</span></div>`).join('')}</div></section>` : ''}
                            ${pRes.length > 0 ? `<section><h3 class="font-black text-[10px] text-stone-400 mb-2 uppercase tracking-widest">매개변수</h3><div class="glass-card p-3 rounded-2xl space-y-2 border shadow-inner">${pRes.map(p => `<div class="flex items-center gap-4 p-2 bg-white rounded-xl cursor-pointer hover:bg-blue-50 transition-all border shadow-sm" onclick="app.appendToTest('${p.code}')"><code class="text-blue-600 font-bold text-xs">${p.code}</code><span class="text-[11px] font-bold text-slate-700">${p.desc}</span></div>`).join('')}</div></section>` : ''}
                        </div>
                    </div>
                `;
            },

            copyToClipboard(text) {
                const textArea = document.createElement("textarea");
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                textArea.remove();
                this.showToast(`복사됨: ${text}`);
            },

            showToast(msg) {
                const notice = document.createElement('div');
                notice.className = "fixed bottom-10 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-6 py-3 rounded-full text-xs font-bold shadow-2xl z-[100] animate-in slide-in-from-bottom-5 border border-slate-700 shadow-blue-900/20";
                notice.innerHTML = `<span class="text-blue-400 mr-2 font-black">✓</span> ${msg}`;
                document.body.appendChild(notice);
                setTimeout(() => { if(notice) notice.remove(); }, 2000);
            },

            appendToTest(code) {
                this.state.testCommand += (this.state.testCommand ? " " : "") + code;
                const resultBox = document.getElementById('paramResult');
                if (resultBox) resultBox.innerText = this.state.testCommand;
                this.showToast(`추가됨: ${code}`);
            },

            filterParams(cat) { this.state.paramFilter = cat; this.viewParams(document.getElementById('viewContainer')); },
            filterVars(cat) { this.state.varFilter = cat; this.viewVars(document.getElementById('viewContainer')); },
            clearTest() { this.state.testCommand = ""; const box = document.getElementById('paramResult'); if(box) box.innerText = "..."; },
            copyVal(id) { const text = document.getElementById(id).innerText; if(text !== "...") this.copyToClipboard(text); }
        };

        window.onload = () => app.init();
    </script>
</body>
</html>
